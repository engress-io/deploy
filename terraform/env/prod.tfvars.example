# Engress production Terraform intent (canonical copy — live value in SSM engress-terraform-tfvars)

environment               = "prod"
aws_region                = "us-east-2"
admin_email               = "walter@ghostweasel.net"
operator_cidr             = "0.0.0.0/0"
elastic_ip_address        = "18.216.236.251"
name_prefix               = "engress"
base_domain               = "engress.io"
domain_suffix             = ".edge.engress.io"
enable_control_instance   = true
edge_origin_hostname      = "edge-origin-east.engress.io"
control_origin_hostname   = "core-origin-east.engress.io"
enable_frontend           = true
enable_eks                = true
enable_eks_west           = true
enable_global_accelerator = true
decommission_ec2          = true
deploy_target             = "eks"
spa_bucket_name           = "flux-spa-327796148992"
amplify_domain            = "main.dftigsyg375wb.amplifyapp.com"

# EKS sizing — start on t4g.small; scale out via desired/max before bumping instance type.
eks_system_node_instance_type   = "t4g.small"
eks_system_node_min_size        = 2
eks_system_node_desired_size    = 2
eks_system_node_max_size        = 6
eks_workload_node_instance_type = "t4g.small"
eks_workload_node_min_size      = 2
eks_workload_node_desired_size  = 2
eks_workload_node_max_size      = 8
