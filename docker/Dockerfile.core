# syntax=docker/dockerfile:1
# engress-core control plane (Neon + Clerk via SSM). Build via scripts/deploy/scripts/build.sh.
FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates curl && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY bin/engress-core /usr/local/bin/engress-core
EXPOSE 8080
ENTRYPOINT ["engress-core"]
CMD ["serve", "--config", "/data/api.yaml"]
